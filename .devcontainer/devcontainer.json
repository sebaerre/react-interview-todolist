{
  "name": "Frontend",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  "postCreateCommand": "npm install && npx playwright install chromium && npx playwright install-deps chromium",
  "postStartCommand": "npm run dev -- --host",
  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code"]
    }
  },
  "forwardPorts": [5173, 3333],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "openBrowser"
    },
    "3333": {
      "label": "Playwright UI",
      "onAutoForward": "openBrowser"
    }
  }
}
